# Django Core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=Africa/Cairo

# Database
DATABASE_URL=
DB_NAME=personal_os
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# API Keys
AI_PROVIDER=deterministic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=20
ANTHROPIC_MAX_TOKENS=1400

# Telegram Integration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# AppSettings bootstrap defaults
# These values are only used when no persisted AppSettings row exists yet.
CURRENCY_EUR_USD_RATE=1.08
CURRENCY_EUR_EGP_RATE=33.50
INDEPENDENT_INCOME_TARGET_EUR=1000
EMPLOYMENT_INCOME_SOURCE_NAME=K Line Europe
KYRGYZSTAN_GOAL_CODE=g1
INDEPENDENT_INCOME_GOAL_CODE=g2
APP_SETTINGS_TIMEZONE=Africa/Cairo

# Backup Storage
BACKUP_STORAGE_KEY=your-backup-key
BACKUP_STORAGE_SECRET=your-backup-secret
BACKUP_BUCKET_NAME=personal-os-backups
